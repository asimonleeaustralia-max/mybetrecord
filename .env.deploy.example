# Copy to .env.deploy and fill in values. Used by scripts/deploy.sh from Cursor
# or the terminal. Never commit .env.deploy.

# Azure target
RESOURCE_GROUP=mybetrecord-rg
LOCATION=australiaeast
# AZURE_SUBSCRIPTION_ID=   # optional — pin a subscription after az login

# Required secrets (generate with: openssl rand -hex 32 / openssl rand -base64 24)
PG_ADMIN_PASSWORD=
JWT_SECRET=

# Production CORS (use your frontend URL after first deploy)
CORS_ORIGINS=*

# Comma-separated emails always granted admin (on register, login, and startup)
BOOTSTRAP_ADMIN_EMAILS=asimonlee@gmail.com

# Custom domains bound to the frontend Container App after each deploy
CUSTOM_HOSTNAMES=www.mybetrecord.com,mybetrecord.com

# Password reset (auth service — required for working reset links in production)
FRONTEND_URL=https://www.mybetrecord.com
PASSWORD_RESET_MINUTES=60

# Outbound email (required in production — without SMTP_HOST, reset emails are not sent)
# Example: SendGrid SMTP — host smtp.sendgrid.net, user apikey, password = your API key
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@mybetrecord.com
SMTP_USE_TLS=true

# Free plan: max single bets a free user can enter per day (Pro is unlimited)
FREE_DAILY_BET_LIMIT=5
# Free plan: max multiple/parlay bets a free user can enter per day (Pro is unlimited)
FREE_DAILY_MULTIPLE_LIMIT=5
# Maximum number of legs (selections) allowed in a multiple/parlay
MAX_PARLAY_LEGS=10

# Stripe (optional — required only to enable Pro upgrades)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Existing Stripe Product for Pro prices (optional; inline data used when unset)
STRIPE_PRODUCT_ID=
# Legacy single-price id — no longer used (prices are built per-currency)
STRIPE_PRICE_ID=
