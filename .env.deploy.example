# Copy to .env.deploy and fill in values. Used by scripts/deploy.sh from Cursor
# or the terminal. Never commit .env.deploy.

# Azure target
RESOURCE_GROUP=mybetrecord-rg
LOCATION=australiaeast
# AZURE_SUBSCRIPTION_ID=   # optional — pin a subscription after az login

# Required secrets (generate with: openssl rand -hex 32 / openssl rand -base64 24)
PG_ADMIN_PASSWORD=
JWT_SECRET=

# Production CORS (use your frontend URL after first deploy)
CORS_ORIGINS=*

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
