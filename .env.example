# Copy to .env for local runs (docker-compose reads its own defaults; these
# matter when running a service directly with uvicorn).
DATABASE_URL=postgresql+psycopg://betrecord:betrecord@localhost:5432/betrecord
JWT_SECRET=dev-only-change-me
ENVIRONMENT=development
CORS_ORIGINS=*

# Comma-separated emails always granted admin (on register, login, and startup)
BOOTSTRAP_ADMIN_EMAILS=asimonlee@gmail.com

# Password reset (auth service only)
# Site origin — reset links are built as {FRONTEND_URL}/app/#/reset-password/{token}
FRONTEND_URL=http://localhost:8080
PASSWORD_RESET_MINUTES=60

# Outbound email (optional in development — emails print to auth service logs)
# Any SMTP provider works (SendGrid, Mailgun, Gmail, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@mybetrecord.com
SMTP_USE_TLS=true

# Free plan: max bets a free user can enter per day (Pro is unlimited)
FREE_DAILY_BET_LIMIT=5

# Stripe (optional — required only to enable Pro upgrades)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Existing Stripe Product to attach Pro prices to (optional; inline product
# data is used when unset). Pro prices per currency live in code (pricing.py).
STRIPE_PRODUCT_ID=
# Legacy single-price id — no longer used (prices are built per-currency).
STRIPE_PRICE_ID=
